  m_Script: {fileID: 11500000, guid: 257dda874442a0e449c197b01978c789, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CharacterSelector
  characterDropdown: {fileID: 1170022973}
  characterObjects:
  - {fileID: 2135704086}
  - {fileID: 1284969141}
  descriptionText: {fileID: 0}
  characterDescriptions:
  - "Drosm\u012Bgs uguns burvis no seno laiku kara\u013Cvalsts. Vi\u0146\u0161 ir
    slavens ar savu neuzvaramo uguns bru\u0146u komplektu un uguns zobenu. Uguns
    burvis ir c\u012Bn\u012Bjies neskait\u0101m\u0101s kauj\u0101s un vienm\u0113r
    aizst\u0101v\u0113jis v\u0101jos."
  - "Nosl\u0113pumains ledus burvis, kur\u0161 apguvis seno ma\u0123iju. Vi\u0146\u0161
    p\u0101rvalda ledus un zibens burv\u012Bbas. Vi\u0146a burvju n\u016Bja ir izgatavota
    no Pasaules ledus koka zara."
